DATABASE_URL="postgresql://cn:cn_dev_password@localhost:5433/cloudnexus"
JWT_SECRET="replace_with_a_long_random_string_min_32_chars"
PORT=4000
# Comma-separated allowed browser origins. localhost and 127.0.0.1 are paired automatically.
CORS_ORIGIN=http://localhost:3000

# Admin 2FA email (Gmail / Google Workspace App Password recommended)
# Never commit real values — copy to backend/.env only.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_without_or_with_spaces
SMTP_FROM=Cloud Nexus <your.email@gmail.com>

# Never enable in production. If false, OTP is only sent by email (or request fails with 503).
ADMIN_OTP_EXPOSE_DEV_CODE=false


